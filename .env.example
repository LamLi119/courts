# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Webflow courts listing form (server-side only — do NOT prefix with VITE_)
# Generate a site token at https://developers.webflow.com/ with forms:read scope.
WEBFLOW_API_TOKEN=your-webflow-site-api-token
WEBFLOW_SITE_ID=64a3d87da25bdfc447bb9470
WEBFLOW_FORM_NAME=Courts Form
WEBFLOW_PAGE_ID=6a4cc976d5d448ff93b2b52c

# Notion blog sync (server-side only — do NOT prefix with VITE_)
# Create an internal integration at https://www.notion.so/my-integrations
# Share the blog database with the integration (Connections).
NOTION_API_TOKEN=secret_xxxxxxxx
NOTION_BLOG_DATABASE_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa

# IndexNow (server-side) — must match public/<key>.txt on Vercel
INDEXNOW_KEY=a7f3c9e2b18d4f6a0e5c2b9d7f1a8e3c
SITEMAP_BASE_URL=https://courts.theground.io

# Phase 4 SEO monitoring scripts (optional overrides)
