{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/venues-bootstrap.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://courts.api.theground.io/api/sitemap.xml"
    },
    {
      "source": "/okf.tar.gz",
      "destination": "https://courts.api.theground.io/api/okf.tar.gz"
    },
    {
      "source": "/okf",
      "destination": "https://courts.api.theground.io/api/okf"
    },
    {
      "source": "/okf/:path*",
      "destination": "https://courts.api.theground.io/api/okf/:path*"
    },
    {
      "source": "/((?!assets/|sw\\.js|workbox-|manifest\\.webmanifest|robots\\.txt|llms\\.txt|venues-bootstrap\\.json|okf(?:\\.tar\\.gz|/.*)?$|a7f3c9e2b18d4f6a0e5c2b9d7f1a8e3c\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
