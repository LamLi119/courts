{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/venues-bootstrap.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|sw\\.js|workbox-|manifest\\.webmanifest|sitemap\\.xml|robots\\.txt|venues-bootstrap\\.json).*)",
      "destination": "/index.html"
    }
  ]
}
