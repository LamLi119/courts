{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/venues/:slug/", "destination": "/api/html-venue?slug=:slug" },
    { "source": "/venues/:slug", "destination": "/api/html-venue?slug=:slug" },
    { "source": "/venues/:slug*", "destination": "/api/html-venue?slug=:slug*" },
    { "source": "/((?!api/|assets/|sw\\.js|workbox-|manifest\\.webmanifest).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.{ts,js}": {
      "includeFiles": "{lib/**,dist/index.html}"
    }
  }
}
